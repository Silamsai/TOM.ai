# REACT_APP_API_URL — Backend API base URL
# In development: http://localhost:5000/api
# In production: https://your-railway-app.railway.app/api
REACT_APP_API_URL=http://localhost:5000/api

# ── 3D & custom assets (see public/assets/ASSETS_GUIDE.md) ──
REACT_APP_USE_3D=false
# REACT_APP_LOGO_PRIMARY=/assets/logos/logo-primary.png
# REACT_APP_LOGO_3D=/assets/logos/logo-animated.glb
# REACT_APP_HERO_MODEL=/assets/3d/hero-scene.glb
